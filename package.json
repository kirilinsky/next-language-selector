{
  "name": "next-language-selector",
  "version": "0.3.1",
  "description": "Configurable language selector for Next.js",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "npx vitest run --coverage"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "next": "^15.0.0 || ^16.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "keywords": [
    "next.js",
    "i18n",
    "language",
    "language-selector",
    "internationalization",
    "react",
    "cookie-based-i18n",
    "app-router"
  ],
  "author": "Kirilinsky (https://github.com/kirilinsky)",
  "license": "MIT",
  "homepage": "https://github.com/kirilinsky/next-language-selector#readme",
  "bugs": {
    "url": "https://github.com/kirilinsky/next-language-selector/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kirilinsky/next-language-selector.git"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.2",
    "happy-dom": "^20.8.9",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "sideEffects": false,
  "packageManager": "pnpm@10.32.1"
}